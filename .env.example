# Chave da API da Anthropic (Claude). Obtenha em https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Configurações opcionais (valores padrão definidos em app/config.py) ---

# Modelo de geração
# RAG_CLAUDE_MODEL=claude-opus-4-8

# Modelo de embeddings local (sentence-transformers, otimizado p/ recuperação)
# RAG_EMBEDDING_MODEL=intfloat/multilingual-e5-small

# Limiar mínimo de similaridade de cosseno (PRD §6.1)
# RAG_SIMILARITY_THRESHOLD=0.78

# Número de blocos recuperados por consulta
# RAG_TOP_K=5
